page {
  background: #f5f7fa;
  font-size: 28rpx;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.container { padding: 24rpx; }

/* 通用卡片 */
.card {
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}
.card .title { font-size: 30rpx; font-weight: 600; margin-bottom: 8rpx; }
.card .meta { font-size: 26rpx; color: #999; margin-bottom: 8rpx; }

/* 通用按钮 */
button[type="primary"] { background: #1296db; border-radius: 12rpx; font-size: 28rpx; }
button[type="primary"]:active { opacity: .8; }
button[type="warn"] { background: #f56c6c; border-radius: 12rpx; font-size: 28rpx; color: #fff; }
button[size="mini"] { border-radius: 8rpx; font-size: 24rpx; }

/* 通用输入框 */
.input, .textarea { border: 2rpx solid #e8e8e8; padding: 0 20rpx; border-radius: 12rpx; background: #fafafa; font-size: 28rpx; width: 100%; box-sizing: border-box; height: 80rpx; line-height: 80rpx; transition: border-color .2s; }
.input:focus, .textarea:focus { border-color: #1296db; background: #fff; }

/* 标题 */
.page-title { font-size: 36rpx; font-weight: 700; margin-bottom: 28rpx; color: #1a1a1a; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; color: #333; }

/* 空状态 */
.empty { text-align: center; color: #bbb; padding: 120rpx 0; font-size: 28rpx; }
.empty::before { content: '🕊️'; display: block; font-size: 80rpx; margin-bottom: 20rpx; }

/* 标签 */
.tag {
  display: inline-block; padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 22rpx; font-weight: 500;
}
.tag-success { background: #f0f9eb; color: #67c23a; }
.tag-warning { background: #fdf6ec; color: #e6a23c; }
.tag-danger { background: #fef0f0; color: #f56c6c; }
.tag-info { background: #f4f4f5; color: #909399; }
