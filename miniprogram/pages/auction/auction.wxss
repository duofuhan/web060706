.container { padding: 24rpx; }
.auction-img { width: 100%; border-radius: 16rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.08); }
.auction-title { font-size: 36rpx; font-weight: 700; margin-bottom: 16rpx; color: #1a1a1a; }
.info-card { background: #f5f7fa; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #eee; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #999; }
.info-value { font-size: 28rpx; font-weight: 600; color: #f56c6c; }
