.container { padding: 24rpx; }
.auction-header { font-size: 34rpx; font-weight: 700; margin-bottom: 24rpx; color: #1a1a1a; }
.item-img { width: 100%; border-radius: 16rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.08); }
.price-row { display: flex; gap: 20rpx; margin-bottom: 28rpx; }
.price-box { flex: 1; text-align: center; padding: 24rpx; border-radius: 16rpx; background: #f5f7fa; }
.price-box.highlight { background: #fef0ef; }
.price-label { font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.price-value { font-size: 44rpx; font-weight: 700; color: #f56c6c; }
.input { border: 2rpx solid #eee; padding: 24rpx; border-radius: 12rpx; margin-bottom: 20rpx; font-size: 28rpx; background: #fafafa; }
.input:focus { border-color: #1296db; background: #fff; }
.bid-list { margin-top: 40rpx; }
.bid-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; color: #666; padding-bottom: 12rpx; border-bottom: 2rpx solid #f0f0f0; }
.bid-item { display: flex; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.bid-rank { width: 60rpx; color: #bbb; font-size: 24rpx; }
.bid-user { flex: 1; font-size: 26rpx; color: #333; }
.bid-amount { font-size: 28rpx; font-weight: 600; color: #f56c6c; margin-right: 20rpx; }
.bid-time { font-size: 22rpx; color: #bbb; }
.login-prompt { text-align: center; padding: 120rpx 0; }
.login-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.login-msg { font-size: 36rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.login-desc { font-size: 28rpx; color: #999; margin-bottom: 40rpx; }
