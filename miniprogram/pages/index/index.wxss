.header { font-size: 36rpx; font-weight: 600; margin-bottom: 24rpx; }
.empty { text-align: center; color: #999; padding: 100rpx 0; }
.card {
  background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.05);
}
.card .title { font-size: 32rpx; font-weight: 600; margin-bottom: 12rpx; }
.card .meta { font-size: 26rpx; color: #e64340; margin-bottom: 12rpx; }
.status.live { font-size: 24rpx; color: #e64340; }