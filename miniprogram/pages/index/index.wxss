.header {
  font-size: 34rpx; font-weight: 700; margin-bottom: 24rpx;
  padding: 20rpx 0; color: #1a1a1a;
}
.empty { text-align: center; color: #bbb; padding: 120rpx 0; font-size: 28rpx; }
.empty::before { content: '🕊️'; display: block; font-size: 80rpx; margin-bottom: 20rpx; }
.card {
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
  display: flex; gap: 16rpx; transition: transform .2s;
}
.card:active { transform: scale(.98); }
.thumb { width: 160rpx; height: 160rpx; border-radius: 12rpx; flex-shrink: 0; }
.card-body { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.card-body .title { font-size: 30rpx; font-weight: 600; margin-bottom: 8rpx; color: #1a1a1a; }
.card-body .meta { font-size: 26rpx; color: #f56c6c; font-weight: 500; margin-bottom: 12rpx; }
.status-tag {
  display: inline-block; padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 22rpx; font-weight: 500; align-self: flex-start;
}
.status-live { background: #fef0ef; color: #f56c6c; }
.status-scheduled { background: #f0f9eb; color: #67c23a; }
.status-settled { background: #f4f4f5; color: #909399; }
.status-ended { background: #f4f4f5; color: #909399; }
