.login-wrap {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #87CEEB 0%, #5BC0EB 100%);
}
.login-card {
  width: 85%;
  max-width: 500rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,.15);
}
.login-title {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 40rpx;
  color: #1a1a1a;
}
.login-input {
  border: 2rpx solid #eee;
  padding: 0 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  background: #fafafa;
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  transition: border-color .2s;
}
.login-input:focus { border-color: #667eea; background: #fff; }
.btn-wrap { display: flex; justify-content: flex-end; margin-top: 12rpx; }
.btn-login { width: 200rpx; border-radius: 12rpx; }
.switch { text-align: center; color: #667eea; margin-top: 32rpx; font-size: 28rpx; }
