.profile-card {
  background: linear-gradient(135deg, #87CEEB 0%, #5BC0EB 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  color: #fff;
  position: relative;
}
.profile-card:active { opacity: .9; }
.profile-row { display: flex; align-items: center; }
.profile-card .avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: rgba(255,255,255,.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; flex-shrink: 0;
}
.profile-info { flex: 1; margin-left: 24rpx; }
.profile-card .name { font-size: 34rpx; font-weight: 600; margin-bottom: 6rpx; }
.profile-card .role { font-size: 26rpx; opacity: .85; display: inline-flex; align-items: center; gap: 4rpx; }
.profile-card .arrow { font-size: 40rpx; color: rgba(255,255,255,.6); flex-shrink: 0; }

.menu-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx;
  margin-bottom: 32rpx;
}
.menu-grid .menu-item {
  background: #fff; border-radius: 16rpx; padding: 32rpx 24rpx;
  text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}
.menu-grid .menu-item .icon { font-size: 52rpx; margin-bottom: 12rpx; }
.menu-grid .menu-item .label { font-size: 26rpx; color: #333; font-weight: 500; }
.menu-grid .menu-item:active { transform: scale(.96); opacity: .8; }

.action-btns { margin-top: 20rpx; display: flex; gap: 20rpx; }
.action-btn {
  flex: 1; background: #fff; border-radius: 16rpx; padding: 24rpx;
  text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
  font-size: 28rpx; color: #333;
}
.action-btn.logout { color: #f56c6c; }

/* modal */
.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,.4);
  z-index: 99;
}
.modal {
  position: fixed; left: 50%; top: 50%;
  transform: translate(-50%,-50%);
  width: 80%; max-height: 70vh;
  background: #fff; border-radius: 20rpx;
  padding: 32rpx; z-index: 100;
  display: flex; flex-direction: column;
}
.modal-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; text-align: center; }
.account-list { max-height: 500rpx; }
.account-item {
  display: flex; align-items: center;
  padding: 24rpx 16rpx; border-bottom: 1px solid #f0f0f0;
  position: relative;
}
.account-item:active { background: #f5f5f5; }
.account-item.current { background: #f0f9ff; }
.account-item .account-info { flex: 1; }
.account-item .account-name { font-size: 28rpx; font-weight: 500; }
.account-item .account-check { color: #1296db; font-size: 32rpx; margin-right: 16rpx; font-weight: 600; }
.account-item .account-del {
  width: 40rpx; height: 40rpx; line-height: 40rpx;
  text-align: center; font-size: 32rpx; color: #ccc;
}
.account-item .account-del:active { color: #f56c6c; }
.account-item.add { justify-content: center; color: #1296db; }

.add-form { display: flex; flex-direction: column; gap: 20rpx; }
.add-input {
  border: 1px solid #ddd; padding: 16rpx; border-radius: 8rpx;
  font-size: 28rpx;
}
.add-actions { display: flex; gap: 16rpx; justify-content: center; margin-top: 8rpx; }
