<view class="container">
  <view class="title">我的拍品</view>
  <view wx:if="{{items.length === 0}}" class="empty">暂无拍品,快去发布吧</view>
  <view wx:else>
    <view class="card" wx:for="{{items}}" wx:key="id">
      <view class="title">{{item.name}}</view>
      <view class="meta">起拍 ¥{{item.startPrice}} · 成色 {{item.condition}}</view>
      <view class="status {{item.status}}">{{statusMap[item.status] || item.status}}</view>
      <view wx:if="{{item.status === 'approved' && !item.auction}}" style="margin-top:16rpx">
        <button size="mini" type="primary" data-id="{{item.id}}" bindtap="startAuction">开启拍卖</button>
      </view>
      <view wx:elif="{{item.status === 'approved' && item.auction}}" style="margin-top:16rpx">
        <view class="status-label">已有拍卖场次 ({{item.auction.status === 'scheduled' ? '待开始' : item.auction.status === 'live' ? '进行中' : '已结束'}})</view>
      </view>
    </view>
  </view>
</view>