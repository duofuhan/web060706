.title { font-size: 34rpx; font-weight: 600; margin-bottom: 24rpx; }
.empty { text-align: center; color: #999; padding: 100rpx 0; }
.card { background:#fff; padding:24rpx; border-radius:12rpx; margin-bottom:20rpx; }
.card .title { font-size: 30rpx; font-weight: 600; margin-bottom: 8rpx; }
.card .meta { font-size: 26rpx; color: #666; margin-bottom: 12rpx; }
.status { display: inline-block; padding: 4rpx 16rpx; border-radius: 10rpx; font-size: 24rpx; margin-bottom: 16rpx; }
.status.approved { background: #f0f9eb; color: #67C23A; }
.status.pending { background: #fdf6ec; color: #E6A23C; }
.status.rejected { background: #fef0f0; color: #F56C6C; }
.status.draft { background: #f4f4f5; color: #909399; }
.status-label { font-size: 24rpx; color: #909399; }