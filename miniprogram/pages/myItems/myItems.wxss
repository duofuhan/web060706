.page-title { font-size: 34rpx; font-weight: 700; margin-bottom: 24rpx; color: #1a1a1a; }
.empty { text-align: center; color: #bbb; padding: 120rpx 0; font-size: 28rpx; }
.empty::before { content: '📦'; display: block; font-size: 80rpx; margin-bottom: 20rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06); display: flex; gap: 16rpx; }
.thumb { width: 140rpx; height: 140rpx; border-radius: 12rpx; flex-shrink: 0; }
.card-body { flex: 1; }
.card-body .title { font-size: 30rpx; font-weight: 600; margin-bottom: 6rpx; }
.card-body .meta { font-size: 26rpx; color: #999; margin-bottom: 10rpx; }
.status-tag {
  display: inline-block; padding: 4rpx 16rpx; border-radius: 20rpx;
  font-size: 22rpx; font-weight: 500; margin-bottom: 12rpx;
}
.status-tag.approved { background: #f0f9eb; color: #67c23a; }
.status-tag.pending { background: #fdf6ec; color: #e6a23c; }
.status-tag.rejected { background: #fef0f0; color: #f56c6c; }
.status-tag.draft { background: #f4f4f5; color: #909399; }
.status-label { font-size: 24rpx; color: #909399; }
