<scroll-view class="page" scroll-y>
  <view class="page-title">📦 发布拍品</view>

  <view class="form-section">
    <view class="form-label">拍品图片</view>
    <view class="img-grid">
      <view class="img-item" wx:for="{{imageList}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" />
        <view class="del" data-idx="{{index}}" bindtap="removeImage">×</view>
      </view>
      <view class="img-add" wx:if="{{imageList.length < 5}}" bindtap="chooseImage">+</view>
    </view>
  </view>

  <view class="form-section">
    <view class="form-label">拍品名称 *</view>
    <input class="form-input" data-field="name" bindinput="onInput" placeholder="如 iPhone 14 256G" />
  </view>

  <view class="form-section">
    <view class="form-label">成色 *</view>
    <input class="form-input" data-field="condition" bindinput="onInput" placeholder="如 95新 / 9成新" />
  </view>

  <view class="form-section">
    <view class="form-label">原价 *</view>
    <input class="form-input" type="digit" data-field="originPrice" bindinput="onInput" placeholder="购入价" />
  </view>

  <view class="form-section">
    <view class="form-label">起拍价 *</view>
    <input class="form-input" type="digit" data-field="startPrice" bindinput="onInput" />
  </view>

  <view class="form-section">
    <view class="form-label">商品介绍</view>
    <view class="ai-actions">
      <text class="ai-tag" bindtap="optimizeDescription">✨ AI 优化文案</text>
      <text class="ai-tag valuation" bindtap="goValuation">💰 AI 估价</text>
    </view>
    <textarea
      class="form-textarea"
      data-field="description"
      bindinput="onInput"
      value="{{form.description}}"
      placeholder="可点上方 AI 自动生成,也可手动编辑"
      auto-height
      maxlength="-1"
    />
    <view wx:if="{{aiLoading}}" class="loading">AI 正在创作中…</view>
  </view>

  <view class="submit-wrap">
    <button type="primary" bindtap="submit">提交拍品</button>
  </view>
</scroll-view>