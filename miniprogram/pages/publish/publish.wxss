.page {
  height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background: #f5f7fa;
}
.page-title {
  font-size: 36rpx; font-weight: 700; margin-bottom: 32rpx; color: #1a1a1a;
  padding-top: 20rpx;
}
.form-section {
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}
.form-label {
  font-size: 28rpx; color: #666; margin-bottom: 16rpx; font-weight: 500;
}
.form-input, .form-textarea {
  border: 2rpx solid #eee; padding: 0 20rpx; border-radius: 12rpx;
  background: #fafafa; font-size: 28rpx; width: 100%; box-sizing: border-box; height: 80rpx;
}
.form-input:focus, .form-textarea:focus { border-color: #1296db; background: #fff; }
.form-textarea {
  min-height: 160rpx; height: auto; padding: 16rpx 20rpx; line-height: 1.6;
}
.ai-actions { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.ai-tag {
  display: inline-block; padding: 6rpx 16rpx; border: 2rpx solid #1296db;
  border-radius: 24rpx; font-size: 22rpx; color: #1296db; background: #f0f9ff;
}
.ai-tag.valuation { color: #67c23a; border-color: #67c23a; background: #f0f9eb; }
.img-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img-item, .img-add { width: 160rpx; height: 160rpx; border-radius: 12rpx; }
.img-item { position: relative; overflow: hidden; }
.img-item image { width: 100%; height: 100%; }
.img-item .del {
  position: absolute; top: 4rpx; right: 4rpx; width: 36rpx; height: 36rpx;
  background: rgba(0,0,0,.5); color: #fff; font-size: 28rpx; text-align: center;
  line-height: 36rpx; border-radius: 50%;
}
.img-add {
  display: flex; align-items: center; justify-content: center;
  border: 2rpx dashed #ddd; font-size: 60rpx; color: #ccc; background: #fafafa;
}
.loading { color: #999; font-size: 24rpx; margin-top: 12rpx; }
.submit-wrap { margin-top: 16rpx; padding-bottom: 60rpx; }
