.title { font-size: 32rpx; font-weight: 600; margin: 10rpx 0 20rpx; }
.label { font-size: 26rpx; color: #666; margin: 18rpx 0 10rpx; }
.input, .textarea { border: 1px solid #ddd; padding: 16rpx; border-radius: 6rpx; background: #fff; }
.textarea { height: 180rpx; width: 100%; box-sizing: border-box; }
.ai-tag { color: #1296db; font-size: 24rpx; margin-left: 10rpx; }
.loading { color: #999; font-size: 24rpx; margin-top: 8rpx; }
button { margin-top: 40rpx; }

.img-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.img-item, .img-add { width: 160rpx; height: 160rpx; border-radius: 8rpx; }
.img-item { position: relative; overflow: hidden; }
.img-item image { width: 100%; height: 100%; }
.img-item .del { position: absolute; top: 0; right: 0; width: 36rpx; height: 36rpx;
  background: rgba(0,0,0,.5); color: #fff; font-size: 28rpx; text-align: center; line-height: 36rpx; }
.img-add { display: flex; align-items: center; justify-content: center; border: 2rpx dashed #ccc; font-size: 60rpx; color: #999; }