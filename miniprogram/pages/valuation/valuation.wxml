<view class="page">
  <view class="top">AI 估价助手</view>


  <view class="area">
    <view class="empty" wx:if="{{msgs.length === 0 && !loading}}">输入拍品信息,获取起拍价建议</view>

    <view wx:for="{{msgs}}" wx:key="index" class="line {{item.role === 'user' ? 'user' : 'ai'}}">
      <view class="bubble">
        <text user-select>{{item.content}}</text>
      </view>
    </view>

    <view class="line ai" wx:if="{{streamingText}}">
      <view class="bubble">
        <text user-select>{{streamingText}}</text>
      </view>
    </view>

    <view class="line ai" wx:if="{{loading && !streamingText}}">
      <view class="bubble loading">{{loadingText}}…{{elapsed > 0 ? '(' + elapsed + 's)' : ''}}</view>
    </view>
  </view>

  <view class="bar">
    <input value="{{input}}" bindinput="onInput" placeholder="输入问题…" disabled="{{loading}}" />
    <button size="mini" type="primary" bindtap="sendBtn" loading="{{loading}}">发送</button>
  </view>
</view>
