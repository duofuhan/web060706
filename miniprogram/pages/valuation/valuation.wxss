.page { height: 100vh; display: flex; flex-direction: column; background: #f5f5f5; }
.top { padding: 20rpx 24rpx 4rpx; font-size: 34rpx; font-weight: 600; }
.tip { padding: 0 24rpx 8rpx; font-size: 24rpx; color: #67C23A; }

.area {
  flex: 1;
  margin: 0 24rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow-y: auto;
}

.empty { text-align: center; color: #ccc; padding: 100rpx 0; font-size: 28rpx; }

.line { margin-bottom: 20rpx; overflow: hidden; }
.line.user { text-align: right; }
.line.ai { text-align: left; }

.bubble {
  display: inline-block;
  max-width: 80%;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  text-align: left;
  word-break: break-all;
}

.line.user .bubble { background: #1296db; color: #fff; }
.line.ai .bubble { background: #eee; color: #333; }

.loading { background: #eee; color: #333; animation: blink 1s infinite; }
@keyframes blink { 0%,100% { opacity:1 } 50% { opacity:0.3 } }

.bar { display: flex; gap: 12rpx; padding: 12rpx 24rpx 30rpx; }
.bar input { flex: 1; border: 1px solid #ddd; padding: 16rpx; border-radius: 8rpx; background: #fff; font-size: 28rpx; }
.bar button { flex-shrink: 0; }